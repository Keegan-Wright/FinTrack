@using FinanceTracker.Models.Request.Classifications
<DialogBase TResponse="AddClassificationsRequest" Title="Add Classification / Tag"
            ResponseConstructor="BuildResponseModel">
    <Content>
        <MudForm @ref="_form">
            <MudGrid>
                <MudItem xs="12">
                    <MudTextField @bind-Value="_classification" Label="Classification / Tag"
                                  Placeholder="Classification / Tag"
                                  For="@(() => _classification)"
                                  Validation="@((string x) => string.IsNullOrWhiteSpace(x) ? "Classification is required" : null)"
                                  Immediate="true"></MudTextField>
                </MudItem>
            </MudGrid>
        </MudForm>
    </Content>
</DialogBase>

@code {

    private MudForm _form = null!;

    private string _classification = string.Empty;
    private async Task<AddClassificationsRequest?> BuildResponseModel()
    {
        await _form.Validate();
        if (!_form.IsValid) return null;

        return new AddClassificationsRequest
        {
            Tag = _classification
        };
    }

}
