@using Microsoft.AspNetCore.SignalR.Client
@using Microsoft.EntityFrameworkCore.Metadata.Internal
@implements IDisposable

@inject NavigationManager NavigationManager

<MudNavMenu>
    <MudNavLink Href="" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Dashboard">Dashboard</MudNavLink>
    <MudNavLink Href="ProviderSetup" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.AccountBox">Setup Provider
    </MudNavLink>
    <MudNavLink Href="Accounts" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.AccountBalance">Accounts
    </MudNavLink>
    <MudNavLink Href="Transactions" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Money">Transactions
    </MudNavLink>
    <MudNavLink Href="HouseholdMembers" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.House">Household
    </MudNavLink>
    <MudNavLink Href="Classifications" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Tag">Classifications /
        Tags
    </MudNavLink>
    <MudNavLink Href="Calendar" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.CalendarMonth">Calendar
    </MudNavLink>
    <MudNavGroup Icon="@Icons.Material.Filled.Report" Title="Reports">
        <MudNavLink Href="Report/ByAccount" Match="NavLinkMatch.All">Spent By Account</MudNavLink>
        <MudNavLink Href="Report/ByCategory" Match="NavLinkMatch.All">Spent By Category</MudNavLink>
        <MudNavLink Href="Report/InTimePeriod" Match="NavLinkMatch.All">Spent In Time Period</MudNavLink>
    </MudNavGroup>
    <MudNavLink Href="Automation" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Settings">Automation
    </MudNavLink>
</MudNavMenu>

@code {

    private HubConnection _hubConnection { get; set; }

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        NavigationManager.LocationChanged += OnLocationChanged;

        await StartBackgroundHub();
    }

    private async Task StartBackgroundHub()
    {
        _hubConnection = new HubConnectionBuilder()
            .WithUrl(NavigationManager.ToAbsoluteUri("/BackgroundProcessing"))
            .WithServerTimeout(TimeSpan.FromSeconds(30))
            .WithKeepAliveInterval(TimeSpan.FromSeconds(15))
            .Build();

        _hubConnection.HandshakeTimeout = TimeSpan.FromSeconds(15);

        _hubConnection.On<DateTime>("BackgroundBankingSyncComplete", (completionTime) =>
        {
            var a = 1;
        });

            await _hubConnection.StartAsync();
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        StateHasChanged();
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= OnLocationChanged;
    }

}
